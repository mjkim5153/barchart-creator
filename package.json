{
  "name": "playwright-mcp-windows11-setup",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright Test + Playwright MCP setup for VS Code on Windows 11",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "pw:install": "playwright install --with-deps chromium",
    "mcp:playwright": "npx @playwright/mcp@latest"
  },
  "devDependencies": {
    "@playwright/test": "latest"
  }
}
